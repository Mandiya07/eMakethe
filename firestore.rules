rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sellers/{sellerId} {
      allow read, write: if true;
    }
    
    match /products/{productId} {
      allow read, write: if true;
    }
    
    match /banners/{bannerId} {
      allow read, write: if true;
    }
    
    match /drivers/{driverId} {
      allow read, write: if true;
    }
    
    match /admins/{adminId} {
      allow read, write: if true;
    }
  }
}
